[Unit]
Description=Scoliosis FastAPI Server
After=network.target

[Service]
User=ec2-user
WorkingDirectory=/home/ec2-user/scoliosis
EnvironmentFile=/home/ec2-user/scoliosis/.env
ExecStart=/home/ec2-user/.venv/bin/uvicorn server.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
